<idea-plugin>
    <id>ai.peachy.terminal-focus</id>
    <name>Peachy Terminal Focus</name>
    <vendor url="https://github.com/Sebastian-Su/peachy-code">Peachy</vendor>
    <description>Allows Peachy Code to focus specific terminal tabs in JetBrains IDEs.</description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <httpRequestHandler implementation="ai.peachy.terminalfocus.PeachyTerminalFocusHandler"/>
    </extensions>
</idea-plugin>
